# Copy to .env and fill real values. Never commit .env.
# Production: this file on the VPS is injected into rasa_backend via
# docker-compose env_file. After edits you MUST recreate the container:
#   ./scripts/deploy-backend.sh
# See docs/DEPLOYMENT_SECRETS.md

PORT=8092
MONGO_URI=
NODE_ENV=production

FRONTEND_URL=https://therasastore.in
STORE_URL=https://therasastore.in
ADMIN_URL=https://admin.therasastore.in
# Extra allowed origins (comma-separated)
CORS_ORIGINS=https://www.therasastore.in
JWT_SECRET=

# PhonePe Payment Gateway (REQUIRED in production — server will exit if missing)
PHONEPE_ENV=production
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_VERSION=1
PHONEPE_CLIENT_SECRET=
PHONEPE_MERCHANT_ID=
PHONEPE_ENABLED=true

# Configure same values in PhonePe Dashboard → Webhooks (SHA auth)
# URL: https://<api-host>/api/webhooks/phonepe
PHONEPE_WEBHOOK_USERNAME=
PHONEPE_WEBHOOK_PASSWORD=

# Optional crash monitoring (https://sentry.io)
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Daily backups: node script/backupMongo.js
BACKUP_DIR=
BACKUP_RETENTION_DAYS=14

# --- Email (OTP / transactional) ---
# Prefer Resend in production (Gmail SMTP often blocked on cloud hosts):
# RESEND_API_KEY=re_xxx
# RESEND_FROM=RASA <notify@therasastore.in>
# EMAIL_REPLY_TO=support@therasastore.in
#
# Fallback / local SMTP (Gmail app password):
SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM_NAME=RASA

