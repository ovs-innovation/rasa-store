# --- Recommended: Resend (inbox, not spam) ---
# https://resend.com → verify domain → API Keys
RESEND_API_KEY=re_xxxxxxxx
# Prefer notify@ or hello@ — avoid noreply@ (spam filters dislike it)
RESEND_FROM=RASA <notify@rasastore.com>
# Same domain as RESEND_FROM (must be verified in Resend → Domains)
EMAIL_REPLY_TO=support@rasastore.com

# --- Fallback: Gmail (often goes to spam for shop emails) ---
SERVICE=gmail
EMAIL_USER=info@rasastore.com
EMAIL_PASS=16charapppasswordwithoutspaces
EMAIL_FROM_NAME=RASA
EMAIL_REPLY_TO=info@rasastore.com

# Cloudinary (server-side signing/uploads)
# Same cloud as admin/frontend (unsigned preset required in Cloudinary console)
CLOUDINARY_CLOUD_NAME=dse9adftu
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Or Brevo SMTP (300 free/day) ---
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_USER=your-brevo-login-email
# EMAIL_PASS=brevo-smtp-key

STORE_URL=https://rasastore.com
FRONTEND_URL=https://rasastore.com
