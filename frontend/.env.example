# Copy to .env and fill values for local / production.

NEXT_PUBLIC_API_BASE_URL=http://localhost:8092/api
NEXT_PUBLIC_API_SOCKET_URL=http://localhost:8092

# NextAuth — REQUIRED on production host:
# NEXTAUTH_URL=https://therasastore.in
# NEXTAUTH_SECRET=<long random string>
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
