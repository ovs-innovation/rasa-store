# Local
NEXT_PUBLIC_API_BASE_URL=http://localhost:8092/api
NEXT_PUBLIC_API_SOCKET_URL=http://localhost:8092

# --- NextAuth ---
# Local:
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Production (set these on the frontend host / Vercel / etc):
# NEXT_PUBLIC_API_BASE_URL=https://YOUR_API_HOST/api
# NEXT_PUBLIC_API_SOCKET_URL=https://YOUR_API_HOST
# NEXTAUTH_URL=https://therasastore.in
# NEXTAUTH_SECRET=<same long random secret as local>
