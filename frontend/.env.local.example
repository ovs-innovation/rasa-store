# Cloudinary (same cloud as backend; create unsigned upload preset in console)
NEXT_PUBLIC_CLOUDINARY_URL=https://api.cloudinary.com/v1_1/dse9adftu/image/upload
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=E-COMMERCE_INFORMATIVE_CLOUDINARY_UPLOAD_PRESET
NEXT_PUBLIC_CLOUDINARY_API_KEY=your_cloudinary_api_key

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
